{
  "name": "arky-sdk",
  "version": "0.9.11",
  "description": "Official TypeScript SDK for Arky - website backend for custom frontends",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js",
      "require": "./dist/admin.cjs"
    },
    "./storefront": {
      "types": "./dist/storefront.d.ts",
      "import": "./dist/storefront.js",
      "require": "./dist/storefront.cjs"
    },
    "./storefront-store": {
      "types": "./dist/storefront-store.d.ts",
      "import": "./dist/storefront-store.js",
      "require": "./dist/storefront-store.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist",
    "scripts/contract-admin.mjs",
    "scripts/contract-storefront.mjs",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node scripts/check-no-any.mjs",
    "build": "tsup",
    "test": "npm run build && node scripts/contract-storefront.mjs && node scripts/contract-admin.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "arky",
    "sdk",
    "cms",
    "ecommerce",
    "reservations",
    "newsletter",
    "analytics",
    "typescript"
  ],
  "author": "0xDjole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xDjole/arky-sdk.git"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "nanostores": "^1.3.0"
  }
}
